# ==============================================================================
# .env.example — 提交到 Git 的变量模板
# .env         — 真实值，绝不提交 Git（从此文件复制后填写）
#
# 使用方式：
#   cp .env.example .env
#   vim .env   # 填写所有 required 字段
# ==============================================================================

# ── MySQL ──────────────────────────────────────────────────────────────────────
# root 超级用户密码，仅用于容器初始化，应用程序使用 MYSQL_USER 连接
MYSQL_ROOT_PASSWORD=       # required | 建议：openssl rand -base64 32

# 应用数据库名
MYSQL_DATABASE=blog_db

# 应用专用账号（非 root），自动获得 MYSQL_DATABASE 的 GRANT ALL 权限
MYSQL_USER=blog
MYSQL_PASSWORD=            # required | 建议：openssl rand -base64 32

# ── Redis ──────────────────────────────────────────────────────────────────────
# Redis 认证密码（生产环境必须设置，否则任何人都能访问）
REDIS_PASSWORD=            # required | 建议：openssl rand -base64 32

# ── JWT ────────────────────────────────────────────────────────────────────────
# JWT 签名密钥，最少 64 个随机字符（256 bit），泄漏后需立即轮换并强制所有用户重新登录
JWT_SECRET=                # required | 生成：openssl rand -hex 64

# ── Bitiful OSS（S3 兼容对象存储，存储文章图片等文件）──────────────────────────
BITIFUL_ENDPOINT=               # required | 例：https://s3.bitiful.net
BITIFUL_ACCESS_KEY=             # required
BITIFUL_SECRET_KEY=             # required
BITIFUL_BUCKET=blog-module-file # Bucket 名称
BITIFUL_REGION=cn-east-1        # 区域

# ==============================================================================
# .env.example — 提交到 Git 的变量模板
# .env         — 真实值，绝不提交 Git（从此文件复制后填写）
#
# 使用方式：
#   cp .env.example .env
#   vim .env   # 填写所有 required 字段
# ==============================================================================

# ── MySQL ──────────────────────────────────────────────────────────────────────
# root 超级用户密码，仅用于容器初始化，应用程序使用 MYSQL_USER 连接
MYSQL_ROOT_PASSWORD=       # required | 建议：openssl rand -base64 32

# 应用数据库名
MYSQL_DATABASE=blog_db

# 应用专用账号（非 root），自动获得 MYSQL_DATABASE 的 GRANT ALL 权限
MYSQL_USER=blog
MYSQL_PASSWORD=            # required | 建议：openssl rand -base64 32

# ── Redis ──────────────────────────────────────────────────────────────────────
# Redis 认证密码（生产环境必须设置，否则任何人都能访问）
REDIS_PASSWORD=            # required | 建议：openssl rand -base64 32

# ── JWT ────────────────────────────────────────────────────────────────────────
# JWT 签名密钥，最少 64 个随机字符（256 bit），泄漏后需立即轮换并强制所有用户重新登录
JWT_SECRET=                # required | 生成：openssl rand -hex 64

# ── Bitiful OSS（S3 兼容对象存储，存储文章图片等文件）──────────────────────────
BITIFUL_ENDPOINT=               # required | 例：https://s3.bitiful.net
BITIFUL_ACCESS_KEY=             # required
BITIFUL_SECRET_KEY=             # required
BITIFUL_BUCKET=blog-module-file # Bucket 名称
BITIFUL_REGION=cn-east-1        # 区域

# ── Spring Boot Admin ─────────────────────────────────────────────────────────
# Spring Boot Admin Server 登录密码（后端客户端注册时也使用此密码）
ADMIN_SERVER_PASSWORD=            # required | 建议：openssl rand -base64 32

# ── DashScope（阿里云通义千问 AI）──────────────────────────────────────────────
# 用于 Embedding（文章向量化）和 Chat（RAG 问答生成），在 DashScope 控制台创建
DASHSCOPE_API_KEY=                # required | 格式：sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Qdrant Cloud（向量数据库）─────────────────────────────────────────────────
# cloud.qdrant.io → 选择 Cluster → Data Access Control → API Keys → Create
QDRANT_API_KEY=                   # required

# ── Ops Agent（SSH 远程运维 + GitHub Webhook）────────────────────────────────
# GitHub Webhook HMAC-SHA256 密钥（在 GitHub 仓库 Settings > Webhooks > Secret 中配置）
# 留空则跳过验签（仅限本地开发），生产环境必须设置
OPS_WEBHOOK_SECRET=               # required in production | 建议：openssl rand -base64 32

# VPS SSH 连接信息（如与代码默认值相同可不填，以下为默认值注释供参考）
# OPS_SSH_HOST=107.175.36.50      # VPS 公网 IP
# OPS_SSH_USER=blog-ops           # SSH 最小权限用户
# OPS_DEPLOY_DIR=/opt/personal-blog-deploy/personal-blog  # compose.yml 所在目录
